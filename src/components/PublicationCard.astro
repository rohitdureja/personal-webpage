---
import {
  formatAuthors,
  normalizeAssetPath,
  publicationVenue,
  type Publication
} from '../lib/publications';

interface Props {
  publication: Publication;
}

const { publication } = Astro.props;
const summaryPanelId = `summary-${publication.key.replace(/[^a-z0-9_-]/gi, '-')}`;
const links = [
  publication.key === 'Dur20' ? { label: 'Abstract', href: '/thesis-abstract/' } : null,
  publication.preprint
    ? { label: 'Preprint', href: normalizeAssetPath(publication.preprint) }
    : null,
  publication.pdf ? { label: 'PDF', href: normalizeAssetPath(publication.pdf) } : null,
  publication.slides ? { label: 'Slides', href: normalizeAssetPath(publication.slides) } : null,
  publication.website ? { label: 'Website', href: normalizeAssetPath(publication.website) } : null,
  publication.poster ? { label: 'Poster', href: normalizeAssetPath(publication.poster) } : null,
  { label: 'BibTeX', href: `/bibliography/${publication.key}/` }
].filter(Boolean);
---

<article class="publication-card">
  <div class="publication-heading">
    <h3 class="publication-title">
      {
        publication.url ? (
          <a href={publication.url}>{publication.title}</a>
        ) : (
          publication.title
        )
      }
      {publication.award && <span class="award-tag">{publication.award}</span>}
    </h3>
    {publication.year && <span class="publication-year">{publication.year}</span>}
  </div>
  <p class="publication-authors">{formatAuthors(publication.author)}</p>
  <p class="publication-meta">{publicationVenue(publication)}</p>
  <div class="publication-footer">
    <div class="publication-links">
      {
        publication.abstract && (
          <div class="summary-details">
            <button
              type="button"
              class="pill-link ai-summary-link"
              aria-expanded="false"
              aria-controls={summaryPanelId}
            >
              Summary
            </button>
            <div
              id={summaryPanelId}
              class="abstract-panel"
              role="dialog"
              aria-label={`Summary for ${publication.title}`}
            >
              <button type="button" class="summary-close-button" aria-label="Close summary">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M6 6l12 12" />
                  <path d="M18 6 6 18" />
                </svg>
              </button>
              <p>{publication.abstract}</p>
            </div>
          </div>
        )
      }
      {
        links.map((link) => (
          <a class="pill-link" href={link?.href}>
            {link?.label}
          </a>
        ))
      }
    </div>
  </div>
</article>

<script>
  const summaryDetails = Array.from(document.querySelectorAll('.summary-details'));

  const closeSummary = (summary: Element, returnFocus = false) => {
    const button = summary.querySelector('.ai-summary-link');

    summary.classList.remove('is-open');
    button?.setAttribute('aria-expanded', 'false');

    if (returnFocus && button instanceof HTMLElement) {
      button.focus();
    }
  };

  const closeSummaries = (except?: Element) => {
    summaryDetails.forEach((summary) => {
      if (summary !== except) {
        closeSummary(summary);
      }
    });
  };

  summaryDetails.forEach((summary) => {
    const button = summary.querySelector('.ai-summary-link');
    const closeButton = summary.querySelector('.summary-close-button');

    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    button.addEventListener('click', () => {
      const shouldOpen = !summary.classList.contains('is-open');

      closeSummaries(summary);
      summary.classList.toggle('is-open', shouldOpen);
      button.setAttribute('aria-expanded', String(shouldOpen));
    });

    closeButton?.addEventListener('click', () => {
      closeSummary(summary, true);
    });
  });

  document.addEventListener('click', (event) => {
    const target = event.target;

    if (!(target instanceof Node)) {
      return;
    }

    if (!summaryDetails.some((summary) => summary.contains(target))) {
      closeSummaries();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') {
      return;
    }

    const openSummary = summaryDetails.find((summary) => summary.classList.contains('is-open'));

    if (openSummary) {
      event.preventDefault();
      closeSummary(openSummary, true);
    }
  });
</script>
