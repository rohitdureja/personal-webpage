---
import { site } from '../lib/site';

const socialLinks = [
  {
    label: 'Email',
    href: `mailto:${site.email}`,
    icon: 'M2.5 6.5A2.5 2.5 0 0 1 5 4h14a2.5 2.5 0 0 1 2.5 2.5v11A2.5 2.5 0 0 1 19 20H5a2.5 2.5 0 0 1-2.5-2.5v-11Zm2 0L12 11l7.5-4.5M4.5 17.5h15',
    linkClass: 'social-link-light'
  },
  {
    label: 'CV',
    href: '/assets/dureja_cv.pdf',
    textIcon: 'CV',
    linkClass: 'social-link-light'
  },
  {
    label: 'Google Scholar',
    href: 'https://scholar.google.com/scholar?q=%22Rohit+Dureja%22',
    icon: 'M5.242 13.769 0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z',
    svgClass: 'social-brand-icon',
    linkClass: 'social-link-light'
  },
  {
    label: 'DBLP',
    href: 'https://dblp.org/pid/208/7416',
    icon: 'M3.075.002c-.096.013-.154.092-.094.31L4.97 7.73 3.1 8.6s-.56.26-.4.85l2.45 9.159s.16.59.72.33l6.169-2.869 1.3-.61s.52-.24.42-.79l-.01-.06-1.13-4.22-.658-2.45-.672-2.49v-.04s-.16-.59-.84-1L3.5.141s-.265-.16-.425-.139zM18.324 5.03a.724.724 0 0 0-.193.06l-5.602 2.6.862 3.2 1.09 4.08.01.06c.05.47-.411.79-.411.79l-1.88.87.5 1.89.04.1c.07.17.28.6.81.91l6.95 4.269s.68.41.52-.17l-1.981-7.4 1.861-.86s.56-.26.4-.85L18.85 5.42s-.116-.452-.526-.39z',
    svgClass: 'social-brand-icon',
    linkClass: 'social-link-light'
  }
];
---

<section class="hero-card">
  <div class="hero-image-wrap">
    <img class="hero-image" src="/images/portrait.jpg" alt="Portrait of Rohit Dureja" />
  </div>
  <div class="hero-copy">
    <h1>{site.title}</h1>
    <p class="eyebrow keyword-stack">
      <span>Formal Methods · Model Checking</span>
      <span>Hardware Verification · Design Automation</span>
    </p>
    <ul class="social-list">
      {
        socialLinks.map((link) => (
          <li>
            <a class={link.linkClass} href={link.href} aria-label={link.label} title={link.label}>
              {
                'textIcon' in link ? (
                  <span class="social-text-icon" aria-hidden="true">{link.textIcon}</span>
                ) : (
                  <svg class={link.svgClass} viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d={link.icon} />
                  </svg>
                )
              }
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
