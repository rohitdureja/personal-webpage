---
import { role, site } from '../lib/site';

const socialLinks = [
  {
    label: 'Email',
    href: `mailto:${site.email}`,
    icon: 'M2.5 6.5A2.5 2.5 0 0 1 5 4h14a2.5 2.5 0 0 1 2.5 2.5v11A2.5 2.5 0 0 1 19 20H5a2.5 2.5 0 0 1-2.5-2.5v-11Zm2 0L12 11l7.5-4.5M4.5 17.5h15'
  },
  {
    label: 'GitHub',
    href: site.github,
    icon: 'M12 2.5a9.5 9.5 0 0 0-3 18.52c.48.09.66-.2.66-.46v-1.62c-2.7.59-3.27-1.3-3.27-1.3-.44-1.13-1.08-1.43-1.08-1.43-.88-.6.07-.59.07-.59.98.07 1.5 1 1.5 1 .86 1.48 2.26 1.05 2.81.8.08-.63.34-1.05.62-1.29-2.16-.25-4.43-1.08-4.43-4.8 0-1.06.38-1.94 1-2.63-.1-.25-.44-1.25.1-2.6 0 0 .82-.26 2.68 1a9.26 9.26 0 0 1 4.88 0c1.86-1.26 2.68-1 2.68-1 .54 1.35.2 2.35.1 2.6.62.69 1 1.57 1 2.63 0 3.73-2.28 4.55-4.45 4.8.35.3.66.88.66 1.79v2.65c0 .26.18.55.67.46A9.5 9.5 0 0 0 12 2.5Z'
  },
  {
    label: 'Facebook',
    href: site.facebook,
    icon: 'M13.5 8H15V5.5h-1.8c-1.98 0-3.2 1.4-3.2 3.22V10H8v2.5h2v7h2.5v-7h2l.5-2.5h-2.5V8.95c0-.55.45-.95 1-.95Z'
  },
  {
    label: 'Twitter',
    href: site.twitter,
    icon: 'M19.7 6.2c-.52.23-1.08.39-1.67.47a2.9 2.9 0 0 0 1.27-1.6c-.56.34-1.18.58-1.84.71a2.9 2.9 0 0 0-4.94 2.65A8.23 8.23 0 0 1 3.5 5.5a2.9 2.9 0 0 0 .9 3.87c-.44-.01-.86-.13-1.23-.34v.03a2.9 2.9 0 0 0 2.33 2.84c-.42.11-.88.13-1.33.05a2.9 2.9 0 0 0 2.7 2.01A5.8 5.8 0 0 1 3 15.48 8.2 8.2 0 0 0 7.45 17c5.34 0 8.27-4.43 8.27-8.27 0-.13 0-.26-.01-.38a5.9 5.9 0 0 0 1.43-1.48 5.7 5.7 0 0 1-1.65.45 2.9 2.9 0 0 0 1.2-1.6Z'
  }
];
---

<section class="hero-card">
  <div class="hero-image-wrap">
    <img class="hero-image" src="/images/portrait.jpg" alt="Portrait of Rohit Dureja" />
  </div>
  <div class="hero-copy">
    <p class="eyebrow">Formal Methods</p>
    <h1>{site.title}</h1>
    <p class="role-line">{role.jobTitle}</p>
    <p class="meta-line">{role.team}</p>
    <p class="meta-line">{role.company}</p>
    <div class="hero-actions">
      <a class="button button-primary" href="/publications/">View Publications</a>
    </div>
    <ul class="social-list">
      {
        socialLinks.map((link) => (
          <li>
            <a href={link.href} aria-label={link.label} title={link.label}>
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d={link.icon} />
              </svg>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
