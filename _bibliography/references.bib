booktitle = {Proceedings of Formal Modeling and Analysis of Timed Systems (FORMATS)},
publisher = {Springer},
year      = {2023},
abstract  = {This paper studies model predictive runtime verification for cyber-physical systems that must satisfy timing constraints in real time. The approach combines runtime monitoring with predictive reasoning so the monitor can forecast impending violations early enough to enable preventive action, and the paper evaluates the idea on a representative CPS setting with hard deadlines.},
url       = {https://doi.org/10.1007/978-3-031-42626-1_10}
}

